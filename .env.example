# ════════════════════════════════════════════════════════════════
# 16Personalities 자동화 — 환경변수 설정 예시
# 이 파일을 복사해 .env 로 저장 후 값을 채워주세요.
#   cp .env.example .env
# ════════════════════════════════════════════════════════════════

# ── Google Sheets ──────────────────────────────────────────────
# 스프레드시트 ID (URL의 /d/ 뒤 부분)
SPREADSHEET_ID=1ls2D0P9blSeXSz9vMwvLVZFDsUR7fWDQnGbk7O_7Drk

# 구글폼 응답이 쌓이는 시트 이름
SHEET_NAME=설문지 응답 시트

# ── Google 인증 ────────────────────────────────────────────────
# [로컬 개발] Service Account JSON 키 파일 경로
# [Cloud Run] 이 값을 비우면 Application Default Credentials(ADC) 자동 사용
GOOGLE_KEY_FILE=./service-account-key.json

# ── Google Cloud Storage ───────────────────────────────────────
# 실패 스크린샷을 저장할 GCS 버킷명
# 비워두면 로컬 SCREENSHOT_DIR 에 저장
GCS_BUCKET=

# ── 로컬 스크린샷 폴더 (GCS 미설정 시 사용) ───────────────────
SCREENSHOT_DIR=./screenshots

# ── Playwright ────────────────────────────────────────────────
# true  = 브라우저 창 없이 백그라운드 실행 (서버/Docker 필수)
# false = 브라우저 창 표시 (로컬 디버깅 시 유용)
HEADLESS=true

# ── 서버 포트 ─────────────────────────────────────────────────
# Cloud Run은 8080 고정
PORT=8080
